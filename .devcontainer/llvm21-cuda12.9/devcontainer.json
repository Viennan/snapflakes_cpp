{
    "image": "${localEnv:USER}/snapflakes_cpp:llvm21-cuda12.9-dev",
    "name": "snapflakes_cpp-llvm21-cuda12.9-dev",
    "workspaceFolder": "/home/${localEnv:USER}-dev/workspace/repos/snapflakes_cpp",
    "hostRequirements": { "gpu": "optional" },
    "remoteUser": "${localEnv:USER}-dev",
    "containerUser": "${localEnv:USER}-dev",
    "runArgs": [
        "--runtime=nvidia"
    ],
    "containerEnv": {
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "all"
    },
    "mounts": [
        "type=bind,source=${localEnv:HOME}/.ssh,target=/home/${localEnv:USER}-dev/.ssh",
        "type=bind,source=${localEnv:HOME}/.gitconfig,target=/home/${localEnv:USER}-dev/.gitconfig",
        "type=bind,source=${localEnv:HOME}/workspace,target=/home/${localEnv:USER}-dev/workspace"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools-extension-pack",
                "xaver.clang-format",
                "llvm-vs-code-extensions.vscode-clangd",
                "kilocode.kilo-code",
                "marscode.marscode-extension"
            ]
        }
    }
}
